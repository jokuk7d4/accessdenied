# Copy this file to docker/jitsi/.env and update IP/ports if needed.
# This setup runs Jitsi without login/lobby so rooms start immediately.

JITSI_IMAGE_TAG=stable
TZ=Asia/Kolkata

HTTP_PORT=8000
HTTPS_PORT=8443
JVB_PORT=10000
JVB_TCP_HARVESTER_PORT=4443
JVB_TCP_HARVESTER_DISABLED=true

# Change this to your machine LAN IP for local-network access.
# Example: PUBLIC_URL=https://192.168.29.242:8443
PUBLIC_URL=https://localhost:8443
DOCKER_HOST_ADDRESS=127.0.0.1
JVB_ADVERTISE_IPS=127.0.0.1

# Critical flags to avoid "waiting for moderator / login" gate.
ENABLE_AUTH=0
ENABLE_GUESTS=1
ENABLE_LOBBY=0
ENABLE_HSTS=0
ENABLE_PREJOIN_PAGE=0
ENABLE_WELCOME_PAGE=0
ENABLE_AUTO_OWNER=1
AUTH_TYPE=internal

XMPP_DOMAIN=meet.jitsi
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_GUEST_DOMAIN=guest.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
XMPP_BOSH_URL_BASE=http://prosody:5280

JICOFO_COMPONENT_SECRET=change_this_jicofo_component_secret
JICOFO_AUTH_USER=focus
JICOFO_AUTH_PASSWORD=change_this_jicofo_auth_password
JVB_AUTH_USER=jvb
JVB_AUTH_PASSWORD=change_this_jvb_auth_password
JVB_BREWERY_MUC=jvbbrewery
